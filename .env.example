# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- PostgreSQL (with pgvector) ---
# Local dev default. Matches docker-compose (we'll add later).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amazon_scraper

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Thordata proxy (for Amazon HTML fetching) ---
THORDATA_USERNAME=
THORDATA_PASSWORD=
THORDATA_PROXY_SERVER=i2mxeyv4.pr.thordata.net:9999

# --- App ---
LOG_LEVEL=INFO
