# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- PostgreSQL (with pgvector) ---
# Local dev default. Matches docker-compose (we'll add later).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amazon_scraper

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Bright Data Web Unlocker (REST API, recommended) ---
# Token from BD dashboard → User settings → API tokens
# Zone from BD dashboard → My Zones → <your unlocker zone> → Overview
BRIGHTDATA_TOKEN=
BRIGHTDATA_ZONE=web_unlocker1

# --- Plain HTTP proxy (fallback, e.g. residential proxy vendors) ---
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_SERVER=

# --- App ---
LOG_LEVEL=INFO
